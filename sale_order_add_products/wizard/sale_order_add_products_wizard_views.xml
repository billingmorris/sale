<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_add_products_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.add.products.wizard.form</field>
        <field name="model">sale.order.add.products.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar Productos a la Cotización">
                <field name="sale_order_id" invisible="1"/>
                <group>
                    <field name="product_ids" nolabel="1" colspan="2">
                        <tree>
                            <field name="default_code" string="Referencia"/>
                            <field name="name" string="Producto"/>
                            <field name="list_price" string="Precio"/>
                            <field name="uom_id" string="UdM"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="action_add_products"
                            string="Agregar a la Cotización"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
